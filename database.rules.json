{
  "rules": {
    "users": {
      "$uid": {
        "unreadCount": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null",
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "status": {
          ".read": "auth != null",
          ".write": "auth != null && auth.uid == $uid"
        },
        "lastSeen": {
          ".read": "auth != null",
          ".write": "auth != null && auth.uid == $uid"
        },
        "$other": {
          ".read": false,
          ".write": false
        }
      }
    },
    ".read": false,
    ".write": false
  }
}
